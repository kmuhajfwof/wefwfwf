#!/bin/bash
set -e
source /venv/main/bin/activate

WORKSPACE=${WORKSPACE:-/workspace}
COMFYUI_DIR="${WORKSPACE}/ComfyUI"

APT_PACKAGES=()
PIP_PACKAGES=()

# Основной репозиторий с набором нод
ALLNODES_REPO="${ALLNODES_REPO:-https://github.com/kmuhajfwof/ofm-factory.git}"
ALLNODES_BRANCH="${ALLNODES_BRANCH:-main}"

# Дополнительные ноды, которые нужно докинуть в custom_nodes
EXTRA_NODES=(
    "https://github.com/kmuhajfwof/ssssdd"
)

CLIP_MODELS=(
    "https://huggingface.co/f5aiteam/CLIP/resolve/main/umt5_xxl_fp8_e4m3fn_scaled.safetensors"
)

CLIP_VISION_MODELS=(
    "https://huggingface.co/Comfy-Org/Wan_2.1_ComfyUI_repackaged/resolve/main/split_files/clip_vision/clip_vision_h.safetensors"
)

TEXT_ENCODERS=()

VAE_MODELS=(
    "https://huggingface.co/Comfy-Org/Wan_2.1_ComfyUI_repackaged/resolve/main/split_files/vae/wan_2.1_vae.safetensors"
)

CONTROLNET_MODELS=(
    "https://huggingface.co/Kijai/WanVideo_comfy/resolve/main/Wan21_Uni3C_controlnet_fp16.safetensors"
)

DETECTION_MODELS=(
    "https://huggingface.co/Kijai/WanVideo_comfy_fp8_scaled/resolve/main/Wan22Animate/Wan2_2-Animate-14B_fp8_scaled_e4m3fn_KJ_v2.safetensors"
    "https://huggingface.co/Wan-AI/Wan2.2-Animate-14B/resolve/main/process_checkpoint/det/yolov10m.onnx"
    "https://huggingface.co/Kijai/vitpose_comfy/resolve/main/onnx/vitpose_h_wholebody_data.bin"
    "https://huggingface.co/Kijai/vitpose_comfy/resolve/main/onnx/vitpose_h_wholebody_model.onnx"
)

UPSCALER_MODELS=(
    "https://huggingface.co/arhiteector/loras/resolve/main/wanvideohelper/low.pt"
    "https://huggingface.co/arhiteector/loras/resolve/main/wanvideohelper/005_colorDN_DFWB_s128w8_SwinIR-M_noise15.pth"
)

LORAS=(
    "https://huggingface.co/Kijai/WanVideo_comfy/resolve/main/Lightx2v/lightx2v_I2V_14B_480p_cfg_step_distill_rank256_bf16.safetensors"
    "https://huggingface.co/Comfy-Org/Wan_2.2_ComfyUI_Repackaged/resolve/main/split_files/loras/wan2.2_i2v_lightx2v_4steps_lora_v1_high_noise.safetensors"
    "https://huggingface.co/alibaba-pai/Wan2.2-Fun-Reward-LoRAs/resolve/main/Wan2.2-Fun-A14B-InP-low-noise-HPS2.1.safetensors"
    "https://huggingface.co/Kijai/WanVideo_comfy/resolve/main/Pusa/Wan21_PusaV1_LoRA_14B_rank512_bf16.safetensors"
)

DIFFUSION_MODELS=(
    "https://huggingface.co/Kijai/WanVideo_comfy_fp8_scaled/resolve/main/Wan22Animate/Wan2_2-Animate-14B_fp8_scaled_e4m3fn_KJ_v2.safetensors"
)

function log_step() {
    echo ""
    echo "=================================================="
    echo "$1"
    echo "=================================================="
}

function provisioning_start() {
    log_step "STEP 1: apt packages"
    provisioning_get_apt_packages

    log_step "STEP 2: clone ComfyUI"
    provisioning_clone_comfyui

    log_step "STEP 3: install base requirements"
    provisioning_install_base_reqs

    log_step "STEP 4: install custom nodes"
    provisioning_get_nodes

    log_step "STEP 5: install extra pip packages"
    provisioning_get_pip_packages

    log_step "STEP 6: download CLIP models"
    provisioning_get_files "${COMFYUI_DIR}/models/clip" "${CLIP_MODELS[@]}"

    log_step "STEP 7: download CLIP vision models"
    provisioning_get_files "${COMFYUI_DIR}/models/clip_vision" "${CLIP_VISION_MODELS[@]}"

    log_step "STEP 8: download text encoders"
    provisioning_get_files "${COMFYUI_DIR}/models/text_encoders" "${TEXT_ENCODERS[@]}"

    log_step "STEP 9: download VAE"
    provisioning_get_files "${COMFYUI_DIR}/models/vae" "${VAE_MODELS[@]}"

    log_step "STEP 10: download diffusion models"
    provisioning_get_files "${COMFYUI_DIR}/models/diffusion_models" "${DIFFUSION_MODELS[@]}"

    log_step "STEP 11: download controlnet models"
    provisioning_get_files "${COMFYUI_DIR}/models/controlnet" "${CONTROLNET_MODELS[@]}"

    log_step "STEP 12: download detection models"
    provisioning_get_files "${COMFYUI_DIR}/models/detection" "${DETECTION_MODELS[@]}"

    log_step "STEP 13: download LoRA models"
    provisioning_get_files "${COMFYUI_DIR}/models/loras" "${LORAS[@]}"

    log_step "STEP 14: download upscale models"
    provisioning_get_files "${COMFYUI_DIR}/models/upscale_models" "${UPSCALER_MODELS[@]}"

    log_step "PROVISIONING COMPLETE"
}

function provisioning_clone_comfyui() {
    if [[ ! -d "${COMFYUI_DIR}" ]]; then
        echo "Cloning ComfyUI into ${COMFYUI_DIR}"
        git clone https://github.com/comfyanonymous/ComfyUI.git "${COMFYUI_DIR}"
    else
        echo "ComfyUI already exists: ${COMFYUI_DIR}"
    fi
    cd "${COMFYUI_DIR}"
}

function provisioning_install_base_reqs() {
    if [[ -f requirements.txt ]]; then
        echo "Installing ComfyUI base requirements"
        pip install --no-cache-dir -r requirements.txt
    else
        echo "No base requirements.txt found"
    fi
}

function provisioning_get_apt_packages() {
    if [[ ${#APT_PACKAGES[@]} -gt 0 ]]; then
        echo "Installing apt packages: ${APT_PACKAGES[*]}"
        sudo apt update && sudo apt install -y "${APT_PACKAGES[@]}"
    else
        echo "No apt packages to install"
    fi
}

function provisioning_get_pip_packages() {
    if [[ ${#PIP_PACKAGES[@]} -gt 0 ]]; then
        echo "Installing extra pip packages: ${PIP_PACKAGES[*]}"
        pip install --no-cache-dir "${PIP_PACKAGES[@]}"
    else
        echo "No extra pip packages to install"
    fi
}

function provisioning_get_nodes() {
    local custom_nodes_dir="${COMFYUI_DIR}/custom_nodes"
    local temp_repo_dir="${COMFYUI_DIR}/allnodes2_tmp"

    cd "${COMFYUI_DIR}"

    if [[ -z "${custom_nodes_dir}" || "${custom_nodes_dir}" == "/" ]]; then
        echo "ERROR: invalid custom_nodes path: ${custom_nodes_dir}"
        exit 1
    fi

    echo "Cleaning old custom_nodes"
    rm -rf "${custom_nodes_dir}"
    rm -rf "${temp_repo_dir}"

    echo "Cloning main nodes repo: ${ALLNODES_REPO} (branch: ${ALLNODES_BRANCH})"
    git clone --depth 1 --branch "${ALLNODES_BRANCH}" "${ALLNODES_REPO}" "${temp_repo_dir}"

    echo "Moving repo to custom_nodes"
    mv "${temp_repo_dir}" "${custom_nodes_dir}"

    echo "Cloning extra nodes"
    for repo in "${EXTRA_NODES[@]}"; do
        local dir_name="${repo##*/}"
        local target_dir="${custom_nodes_dir}/${dir_name}"

        echo "Extra node: ${repo}"
        if [[ ! -d "${target_dir}" ]]; then
            git clone --depth 1 "${repo}" "${target_dir}" || true
        else
            echo "Already exists: ${target_dir}"
        fi
    done

    echo "Installing requirements from custom_nodes"
    find "${custom_nodes_dir}" -type f -name requirements.txt -print0 | while IFS= read -r -d '' req; do
        echo "Installing requirements: ${req}"
        pip install --no-cache-dir -r "${req}" || true
    done
}

function provisioning_get_files() {
    if [[ $# -lt 2 ]]; then
        echo "No files to download for $1"
        return
    fi

    local dir="$1"
    shift
    local files=("$@")

    mkdir -p "$dir"

    for url in "${files[@]}"; do
        echo "Downloading to ${dir}"
        echo "URL: ${url}"

        local auth_header=""
        if [[ -n "$HF_TOKEN" && "$url" =~ huggingface\.co ]]; then
            auth_header="--header=Authorization: Bearer $HF_TOKEN"
        elif [[ -n "$CIVITAI_TOKEN" && "$url" =~ civitai\.com ]]; then
            auth_header="--header=Authorization: Bearer $CIVITAI_TOKEN"
        fi

        wget $auth_header -nc --content-disposition -P "$dir" "$url" || true

        echo "Finished: ${url}"
        echo ""
    done
}

if [[ ! -f /.noprovisioning ]]; then
    provisioning_start
fi

cd "${COMFYUI_DIR}"
python main.py --listen 0.0.0.0 --port 8188
